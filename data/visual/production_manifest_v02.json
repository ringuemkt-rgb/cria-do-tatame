    {"id": "body_lock_trip", "entry": "clinch", "exit": "player_top_half_guard", "frames_target": 28},
    {"id": "foot_sweep", "entry": "clinch", "exit": "player_top_side", "frames_target": 24},
    {"id": "sprawl", "entry": "takedown_defense", "exit": "player_top_turtle", "frames_target": 20},
    {"id": "guard_pull", "entry": "clinch", "exit": "player_bottom_guard", "frames_target": 20},
    {"id": "raspagem_tesoura", "entry": "player_bottom_guard", "exit": "player_top_guard", "frames_target": 28},
