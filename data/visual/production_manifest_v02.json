{
  "schema_version": 2,
  "project": "cria_do_tatame_pressao",
  "canon_protagonist": "ruan_macacao",
  "target_engine": "Godot 4.3+",
  "target_platforms": ["android_arm64", "windows_x86_64"],
  "visual_style": {
    "name": "HD Pixel Art 2.5D Regional Premium",
    "combat_sprite_height_px": 72,
    "hub_sprite_cell_px": 64,
    "hub_directions": 8,
    "grid_px": 16,
    "texture_filter": "nearest",
    "outline_px": 1,
    "rim_light_px": 1,
    "rules": [
      "silhueta legivel em tela pequena",
      "proporcoes estaveis entre quadros",
      "sem anti-aliasing borrado",
      "sem textos longos incorporados",
      "sem marcas reais",
      "pivo e linha de contato documentados"
    ]
  },
  "quality_gate": {
    "required_files": [
      "raw_sheet.png",
      "clean_sheet.png",
      "spritesheet.png",
      "frames",
      "preview.gif",
      "contact_sheet.png",
      "metadata.json",
      "import_notes.md",
      "qa_report.md"
    ],
    "paired_technique_extra_files": ["attacker", "defender", "sync_map.json", "hitbox.json"],
    "arena_extra_files": ["layers", "props", "collision.json", "camera_bounds.json", "arena.tscn"],
    "audio_extra_files": ["master.wav", "runtime.ogg", "audio_metadata.json"]
  },
  "animation_profiles": {
    "fighter_core": [
      "idle_combat",
      "walk_forward",
      "walk_backward",
      "dash_forward",
      "dash_backward",
      "guard_raise",
      "guard_hold",
      "guard_break",
      "hit_light",
      "hit_heavy",
      "stagger",
      "exhausted_idle",
      "knockdown",
      "technical_standup",
      "victory",
      "defeat"
    ],
    "fighter_clinch": [
      "clinch_entry",
      "pummeling_left",
      "pummeling_right",
      "head_position",
      "posture_break",
      "grip_break",
      "clinch_defense",
      "clinch_exit"
    ],
    "fighter_ground": [
      "guard_top",
      "guard_bottom",
      "half_guard_top",
      "half_guard_bottom",
      "side_control_top",
      "side_control_bottom",
      "mount_top",
      "mount_bottom",
      "back_attack",
      "back_defense",
      "turtle_top",
      "turtle_bottom"
    ],
    "mentor": ["idle", "walk", "sweep_floor", "teach_base", "teach_grip", "corner_advice", "belt_ceremony", "dialogue"],
    "story_npc": ["idle", "walk", "talk", "react_positive", "react_negative", "phone", "leave"]
  },
  "characters": [
    {"id": "ruan_macacao", "role": "protagonist", "profiles": ["fighter_core", "fighter_clinch", "fighter_ground"], "signature": ["silverback_grip", "baiana", "knee_cut", "cem_quilos", "mata_leao"]},
    {"id": "mestre_dende", "role": "mentor", "profiles": ["mentor"], "signature": ["base_raiz", "defesa_calma", "pressao_segura"]},
    {"id": "tinker_bell", "role": "ally", "profiles": ["story_npc"], "signature": []},
    {"id": "davi_relampago", "role": "technical_rival", "profiles": ["fighter_core", "fighter_clinch", "fighter_ground"], "signature": ["sprawl_relampago", "counter_single", "scramble_tecnico"]},
    {"id": "cassio_molho", "role": "underground_promoter", "profiles": ["fighter_core", "fighter_clinch", "story_npc"], "signature": ["dirty_clinch", "crowd_pressure"]},
    {"id": "kenzo_kuroi", "role": "shadow_boss", "profiles": ["fighter_core", "fighter_clinch", "fighter_ground"], "signature": ["silent_counter", "leg_entanglement", "heel_hook_narrative"]},
    {"id": "leoa_quilombola", "role": "ally_rival", "profiles": ["fighter_core", "fighter_clinch", "fighter_ground"], "signature": ["base_de_ferro", "raspagem_quilombo", "triangulo_ancestral"]},
    {"id": "jacare_mangue", "role": "mangrove_boss", "profiles": ["fighter_core", "fighter_clinch", "fighter_ground"], "signature": ["arrasto_da_lama", "guilhotina_do_mangue", "montada_de_raiz"]},
    {"id": "oni_da_lapa", "role": "underground_boss", "profiles": ["fighter_core", "fighter_clinch", "fighter_ground"], "signature": ["carga_oni", "kimura_de_aco", "montada_sombria"]},
    {"id": "delegado_montenegro", "role": "institutional_pressure", "profiles": ["fighter_core", "fighter_clinch", "fighter_ground", "story_npc"], "signature": ["leitura_fria", "clinch_algemado", "wrist_lock_tatico"]},
    {"id": "mestre_guigo", "role": "advanced_coach", "profiles": ["fighter_core", "fighter_clinch", "fighter_ground", "mentor"], "signature": ["body_lock_drive", "leg_drag", "over_under_pass"]}
  ],
  "paired_techniques": [
    {"id": "clinch_entry", "entry": "close_range", "exit": "clinch", "frames_target": 12},
