    {"id": "leg_drag_pass", "entry": "player_top_guard", "exit": "player_top_side", "frames_target": 28},
    {"id": "mount_transition", "entry": "player_top_side", "exit": "player_top_mount", "frames_target": 22},
    {"id": "back_take", "entry": "player_top_turtle", "exit": "player_back_attack", "frames_target": 30},
    {"id": "bridge_escape", "entry": "player_bottom_mount", "exit": "player_top_guard", "frames_target": 24},
    {"id": "elbow_escape", "entry": "player_bottom_mount", "exit": "player_bottom_half_guard", "frames_target": 24},
    {"id": "armbar", "entry": "player_top_mount", "exit": "technical_finish", "frames_target": 42, "phases": ["setup", "lock", "finish"]},
    {"id": "triangle", "entry": "player_bottom_guard", "exit": "technical_finish", "frames_target": 42, "phases": ["setup", "lock", "finish"]},
