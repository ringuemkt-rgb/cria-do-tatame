    "generic_striking_core_forbidden": true,
    "resources": [
      "health",
      "gas",
      "focus",
      "guard",
      "grip",
      "positional_control"
    ],
    "paired_animation_phases": [
      "anticipation",
      "entry",
      "establish",
      "stabilize",
      "response",
      "recovery"
    ],
    "submission_phases": [
      "setup",
      "lock",
      "technical_pressure",
      "tap_or_escape",
      "referee_or_recovery"
    ]
  },
  "asset_pack_contracts": {
    "character": [
      "model_sheet.png",
      "palette.json",
      "spritesheet.png",
      "preview.gif",
      "metadata.json",
      "qa_report.md"
    ],
    "paired_technique": [
      "attacker_spritesheet.png",
      "defender_spritesheet.png",
      "sync_markers.json",
      "preview.gif",
      "metadata.json",
      "qa_report.md"
    ],
    "arena": [
      "background_layers",
      "collision_map.json",
      "occlusion_map.png",
      "lighting_profile.tres",
      "ambience_profile.json",
      "preview.png",
      "qa_report.md"
    ],
    "audio": [
      "source.wav",
      "game.ogg",
      "metadata.json",
      "loudness_report.json",
      "license.txt"
