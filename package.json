{
  "name": "cria-do-tatame",
  "version": "1.0.0",
  "private": true,
  "description": "Cria do Tatame — BJJ positional fighting RPG for Godot, Android, PC and Web.",
  "type": "module",
  "scripts": {
    "start": "python -m http.server 8000",
    "build": "npm run capacitor:sync",
    "validate:python": "python tools/validate_json.py",
    "validate:node": "node tools/node/validate_json.mjs",
    "validate:data": "node tools/node/validate_game_data.mjs",
    "validate:repository": "python tools/validate_complete_game.py",
    "assets:manifest": "node tools/node/generate_asset_manifest.mjs",
    "quality": "npm run validate:python && npm run validate:node && npm run validate:data && npm run validate:repository",
    "capacitor:init": "npx cap init 'CRIA DO TATAME' 'com.criadotatame.app'",
    "capacitor:add:android": "npx cap add android",
    "capacitor:sync": "npx cap sync"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0"
  },
  "engines": {
    "node": ">=20",
    "python": ">=3.10"
  }
}
