# Ordem de fallback: Hugging Face -> OpenRouter -> simulacao deterministica
WORLD_AI_PROVIDER_ORDER=huggingface,openrouter,deterministic
WORLD_PLAN_CACHE_SECONDS=300

# Hugging Face Inference Providers
HF_TOKEN=
HF_WORLD_MODEL=Qwen/Qwen3-4B-Instruct-2507

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_APP_URL=https://github.com/ringuemkt-rgb/cria-do-tatame

# NFT opcional: contratos compativeis com ERC-721/1155
NFT_RPC_URL=
NFT_ERC721_CONTRACT_ADDRESS=
NFT_ERC1155_CONTRACT_ADDRESS=

# Somente desenvolvimento local, nunca producao
NFT_DEV_MODE=false
NFT_DEV_ENTITLEMENTS=rashguard_gorila_prata,patch_terreiro_raiz
