# Copie este arquivo para .env no seu computador.
# Nunca envie .env para o GitHub.

HF_TOKEN=coloque_sua_chave_huggingface_aqui
HF_HOME=.cache/huggingface
HF_ASSET_DEVICE=auto
HF_ASSET_DTYPE=float16
CRIA_ASSET_OUTPUT_DIR=tools/ai_asset_pipeline/generated_outputs
CRIA_ASSET_QUEUE_DIR=tools/ai_asset_pipeline/generated_queue

# Open Pixel Forge local. Use provider=plan para validar sem GPU.
CRIA_FORGE_PROVIDER=plan
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_CHECKPOINT=sd_xl_base_1.0.safetensors
COMFYUI_PIXEL_LORA=pixel-art-xl.safetensors
COMFYUI_LORA_STRENGTH=0.9
CRIA_FORGE_SEED=437042
CRIA_FORGE_WIDTH=1024
CRIA_FORGE_HEIGHT=1024
CRIA_FORGE_STEPS=28
CRIA_FORGE_CFG=6.5
